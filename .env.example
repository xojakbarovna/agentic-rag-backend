# DeepSeek (OpenAI-compatible) API key. Never commit the real value.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional overrides (defaults shown)
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
QDRANT_PATH=/tmp/qdrant_embedded
MAX_RETRIES=2

# Comma-separated list of allowed CORS origins, e.g. https://yourfrontend.com
# If left unset, the API allows all origins but disables credentials (per the
# CORS spec, wildcard origin + credentials cannot be combined).
ALLOWED_ORIGINS=
